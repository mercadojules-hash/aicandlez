{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @workspace/trading-dashboard run dev",
    "start": "pnpm --filter @workspace/trading-dashboard run dev",
    "build": "pnpm --filter @workspace/trading-dashboard run build",
    "preview": "pnpm --filter @workspace/trading-dashboard run serve",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:all": "concurrently --kill-others-on-fail --names \"api,web\" --prefix-colors \"cyan,magenta\" \"pnpm run dev:api\" \"pnpm run dev\"",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
