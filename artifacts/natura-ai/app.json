{
  "expo": {
    "name": "Natura AI",
    "slug": "natura-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/natura-app-icon.png",
    "scheme": "natura-ai",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F8F3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.naturaai.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleDarkContent",
        "NSPhotoLibraryUsageDescription": "Allow Natura AI to access your photo library to update your profile picture.",
        "NSCameraUsageDescription": "Allow Natura AI to access your camera to take a profile photo."
      }
    },
    "android": {
      "backgroundColor": "#F6F8F3",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F6F8F3"
      }
    },
    "web": {
      "favicon": "./public/favicon.png",
      "bundler": "metro",
      "name": "Natura AI",
      "shortName": "Natura",
      "description": "Natural wellness, guided by AI",
      "themeColor": "#5C7F5F",
      "backgroundColor": "#F6F8F3",
      "preferRelatedApplications": false,
      "display": "standalone",
      "startUrl": "/",
      "orientation": "portrait",
      "lang": "en",
      "scope": "/"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
