{
  "expo": {
    "name": "Apex AI Trader",
    "slug": "natura-ai",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "apex-trader",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.naturaai.app",
      "buildNumber": "3",
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "NSPhotoLibraryUsageDescription": "Allow Apex Trader to access your photo library for your profile picture.",
        "NSCameraUsageDescription": "Allow Apex Trader to access your camera to take a profile photo."
      }
    },
    "android": {
      "backgroundColor": "#000000",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./public/favicon.png",
      "bundler": "metro",
      "name": "Apex AI Trader",
      "shortName": "Apex",
      "description": "Institutional AI-powered crypto trading platform",
      "themeColor": "#00aaff",
      "backgroundColor": "#000000",
      "preferRelatedApplications": false,
      "display": "standalone",
      "startUrl": "/",
      "orientation": "portrait",
      "lang": "en",
      "scope": "/"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
