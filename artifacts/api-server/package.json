{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run migrate && pnpm run start",
    "build": "node ./build.mjs",
    "migrate": "node --experimental-strip-types ./src/migrate.ts",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.7",
    "@clerk/express": "^2.1.15",
    "@clerk/shared": "^4.10.2",
    "@dydxprotocol/v4-client-js": "^3.6.0",
    "@msgpack/msgpack": "^3.1.3",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@types/ws": "^8.18.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/scripts": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^4.0.0",
    "pino": "^9",
    "pino-http": "^10",
    "stripe": "^22.1.1",
    "stripe-replit-sync": "1.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/web-push": "^3.6.4",
    "archiver": "^7.0.1",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.7"
  }
}
