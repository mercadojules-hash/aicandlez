# ============================================================================
# Apex Trader — Production Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Generate a secure random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — provided by Railway/Render automatically
DATABASE_URL=postgresql://user:password@host:5432/apex_trader

# ── Authentication (Clerk) ────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Session ───────────────────────────────────────────────────────────────────
# Min 32 random characters — used for session signing
SESSION_SECRET=replace_this_with_a_64_char_random_string

# ── Security — Credential Vault ───────────────────────────────────────────────
# AES-256-GCM vault master key — used to derive per-user encryption keys
# Must be at least 32 characters. DO NOT use the default in production.
VAULT_MASTER_KEY=replace_with_a_secure_32_char_vault_master_key_here

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Public base URL of the API server — used to register Stripe webhook
# Must NOT have a trailing slash
WEBHOOK_BASE_URL=https://api.apexdigital.design

# ── Stripe (set by Replit integration or manually on Railway/Render) ──────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Exchange — Kraken (default) ───────────────────────────────────────────────
# Required ONLY for LIVE order execution. Leave blank for SIMULATION mode.
# KRAKEN_API_KEY=your_kraken_api_key_here
# KRAKEN_API_SECRET=your_kraken_base64_api_secret_here

# Set to "true" ONLY when you are ready for real order execution.
EXCHANGE_LIVE_ENABLED=false

# ── Exchange — Binance (optional) ─────────────────────────────────────────────
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# ── Exchange — Coinbase Advanced Trade (optional) ─────────────────────────────
# Use ADVANCED TRADE API keys (not legacy Coinbase Pro keys).
# Secret is an ECDSA private key in PEM format — newlines as \n:
#   -----BEGIN EC PRIVATE KEY-----\nYOUR_KEY\n-----END EC PRIVATE KEY-----
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# ── Exchange — Crypto.com Exchange (optional) ─────────────────────────────────
# Use Exchange API keys, NOT the Crypto.com App API.
# CRYPTOCOM_API_KEY=
# CRYPTOCOM_API_SECRET=

# ── Exchange — Bybit V5 (optional) ────────────────────────────────────────────
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# ── Exchange — OKX V5 (optional — requires passphrase) ───────────────────────
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=

# ── Exchange — KuCoin V2 (optional — requires passphrase) ────────────────────
# KUCOIN_API_KEY=
# KUCOIN_API_SECRET=
# KUCOIN_PASSPHRASE=

# ── Notifications (optional) ──────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# Must match CLERK_PUBLISHABLE_KEY exactly (VITE_ prefix exposes it to browser)
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Local Development Only ────────────────────────────────────────────────────
# Used by the local dev runner script (dev.sh).  In Replit these are set
# automatically by the workflow runner, so you don't need to change them there.
# API_SERVER_PORT=8080
# VITE_PORT=5173
