# ============================================================================
# Apex Trader — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
# Generate secure random secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Provided automatically by Railway/Render — or set manually for local dev.
# The app runs without a DB (signals + AI still work; persistence is disabled).
DATABASE_URL=postgresql://user:password@host:5432/apex_trader

# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Sign up free at https://clerk.com → create an Application → API Keys
# VITE_CLERK_PUBLISHABLE_KEY must equal CLERK_PUBLISHABLE_KEY (both required)
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY_HERE
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY_HERE
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY_HERE

# ── Session ───────────────────────────────────────────────────────────────────
# Minimum 32 random characters — used for session cookie signing
SESSION_SECRET=REPLACE_WITH_A_64_CHAR_RANDOM_STRING

# ── Security — Credential Vault ───────────────────────────────────────────────
# AES-256-GCM master key for per-user exchange credential encryption.
# Must be at least 32 characters.
# WARNING: Never change this after credentials have been stored — they become unreadable.
VAULT_MASTER_KEY=REPLACE_WITH_A_SECURE_32_CHAR_VAULT_KEY_HERE

# ── Live Trading — Master Switch ──────────────────────────────────────────────
# Must be explicitly "true" to unlock live order execution.
# Defaults to false (paper/simulation mode) for safety.
EXCHANGE_LIVE_ENABLED=false

# ── Exchange — Kraken ─────────────────────────────────────────────────────────
# Required for Kraken live trading (HMAC-SHA512 signed)
KRAKEN_API_KEY=YOUR_KRAKEN_API_KEY
KRAKEN_API_SECRET=YOUR_KRAKEN_API_SECRET_BASE64

# ── Exchange — Binance ────────────────────────────────────────────────────────
BINANCE_API_KEY=YOUR_BINANCE_API_KEY
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET

# ── Exchange — Coinbase Advanced Trade ────────────────────────────────────────
# API key format: organizations/<org_id>/apiKeys/<key_id>
# API secret: ECDSA private key PEM — newlines as \n
COINBASE_API_KEY=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END EC PRIVATE KEY-----\n

# ── Exchange — Crypto.com Exchange ────────────────────────────────────────────
CRYPTOCOM_API_KEY=YOUR_CRYPTOCOM_API_KEY
CRYPTOCOM_API_SECRET=YOUR_CRYPTOCOM_API_SECRET

# ── Exchange — Bybit V5 ───────────────────────────────────────────────────────
# BYBIT_API_KEY=YOUR_BYBIT_API_KEY
# BYBIT_API_SECRET=YOUR_BYBIT_API_SECRET

# ── Exchange — OKX V5 (requires passphrase) ───────────────────────────────────
# OKX_API_KEY=YOUR_OKX_API_KEY
# OKX_API_SECRET=YOUR_OKX_API_SECRET
# OKX_PASSPHRASE=YOUR_OKX_PASSPHRASE

# ── Exchange — KuCoin V2 (requires passphrase) ────────────────────────────────
# KUCOIN_API_KEY=YOUR_KUCOIN_API_KEY
# KUCOIN_API_SECRET=YOUR_KUCOIN_API_SECRET
# KUCOIN_PASSPHRASE=YOUR_KUCOIN_PASSPHRASE

# ── Exchange — Gemini (optional) ──────────────────────────────────────────────
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GEMINI_API_SECRET=YOUR_GEMINI_API_SECRET

# ── Alpaca (Paper + Live Equities) ────────────────────────────────────────────
# Paper trading endpoint: https://paper-api.alpaca.markets
# Live trading endpoint:  https://api.alpaca.markets
ALPACA_API_KEY=YOUR_ALPACA_API_KEY
ALPACA_API_SECRET=YOUR_ALPACA_API_SECRET
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# ── Stripe (Billing — optional) ───────────────────────────────────────────────
# Required only if the billing/subscription module is active
# STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
# WEBHOOK_BASE_URL=https://api.apexdigital.design

# ── Notifications (optional) ──────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
# TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN
# TWILIO_FROM_NUMBER=+15555550000

# ── Local Development Only ────────────────────────────────────────────────────
# Override port for local Vite dev server if 5173 is taken
# VITE_PORT=5173
