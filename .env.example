# ============================================================================
# Apex Trader v1.0.0 — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Generate a secure random key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

# ── Core ────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# App runs in degraded (mock) mode without this — signals + UI still work.
DATABASE_URL=postgresql://postgres:password@localhost:5432/apex_trader

# Express session secret — min 32 random characters
SESSION_SECRET=replace_this_with_a_random_32_char_string_here

# API server port (default: 8080)
# PORT=8080

# Frontend base path (default: /)
# BASE_PATH=/

# Node environment
NODE_ENV=development

# ── Security — Credential Vault ───────────────────────────────────────────────
# AES-256-GCM vault master key — used to derive per-user encryption keys
# Must be at least 32 characters. DO NOT use the default in production.
VAULT_MASTER_KEY=replace_with_a_secure_32_char_vault_master_key_here

# ── Exchange — Kraken (default) ───────────────────────────────────────────────
# Required ONLY for LIVE order execution.
# Leave blank to operate in SIMULATION mode (safe default).
# KRAKEN_API_KEY=your_kraken_api_key_here
# KRAKEN_API_SECRET=your_kraken_base64_api_secret_here

# Set to "true" ONLY when you are ready for real order execution.
EXCHANGE_LIVE_ENABLED=false

# ── Exchange — Binance (optional) ─────────────────────────────────────────────
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# ── Exchange — Coinbase Advanced Trade (optional) ─────────────────────────────
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# ── Exchange — Bybit V5 (optional) ────────────────────────────────────────────
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# ── Exchange — OKX V5 (optional) ──────────────────────────────────────────────
# Note: OKX requires a passphrase in addition to key + secret
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=

# ── Exchange — KuCoin V2 (optional) ───────────────────────────────────────────
# Note: KuCoin requires a passphrase in addition to key + secret
# KUCOIN_API_KEY=
# KUCOIN_API_SECRET=
# KUCOIN_PASSPHRASE=
