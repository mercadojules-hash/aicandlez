# ─────────────────────────────────────────────────────────────────────────────
# Apex Trader — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (optional) ───────────────────────────────────────────────────────
# PostgreSQL connection string.
# If not set, the app starts in mock mode — signals and UI work, but trade
# history, portfolio, and settings are not persisted across restarts.
DATABASE_URL=postgresql://postgres:password@localhost:5432/apex_trader

# ── Session security ──────────────────────────────────────────────────────────
# Any random string of 32+ characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_this_with_a_random_32_char_string_here

# ── API server port (optional) ────────────────────────────────────────────────
# Default: 8080
# PORT=8080

# ── Frontend port (optional) ──────────────────────────────────────────────────
# Default: 5173 (set this in the terminal where you run `pnpm run dev`)
# PORT=5173

# ── Frontend base path (optional) ────────────────────────────────────────────
# Default: /
# Only change this if you are serving the frontend from a sub-path.
# BASE_PATH=/

# ── Kraken API keys (optional) ───────────────────────────────────────────────
# Required ONLY for live order execution. The signal engine and all read-only
# market data use Kraken's public API — no keys needed for those.
# KRAKEN_API_KEY=your_api_key_here
# KRAKEN_API_SECRET=your_api_secret_here
