# ============================================================================
# Apex Trader — Production Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Generate a secure random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — provided by Railway/Render automatically
DATABASE_URL=postgresql://user:password@host:5432/apex_trader

# ── Authentication (Clerk) ────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_lj3ihydlPfIXFalY6qEzkQZkFyYTwm9nqQJgmpjKYq
CLERK_PUBLISHABLE_KEY=pk_test_YXBwYXJlbnQtcXVhaWwtMi5jbGVyay5hY2NvdW50cy5kZXYk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YXBwYXJlbnQtcXVhaWwtMi5jbGVyay5hY2NvdW50cy5kZXYk

# ── Session ───────────────────────────────────────────────────────────────────
# Min 32 random characters — used for session signing
SESSION_SECRET=replace_this_with_a_64_char_random_string

# ── Security — Credential Vault ───────────────────────────────────────────────
# AES-256-GCM vault master key — used to derive per-user encryption keys
# Must be at least 32 characters. DO NOT use the default in production.
VAULT_MASTER_KEY=replace_with_a_secure_32_char_vault_master_key_here

# ── Live Trading — Master Switch ──────────────────────────────────────────────
# Must be explicitly "true" to unlock live order execution.
EXCHANGE_LIVE_ENABLED=true

# ── Exchange — Kraken ─────────────────────────────────────────────────────────
KRAKEN_API_KEY=OTEW3JdC0Nds9IziS52rwp0ZAlH4OATEQuSRkb2D2HeNuteSEpxAWogG
KRAKEN_API_SECRET=s8hJMDgZMNTtaBgQwLuAN+PKUI2Q8B05CwPlR7JKahtv52SC2rtL5M1gWWpg5hZ6vfaGpkP0d5e1c/x4HlIVhw==

# ── Exchange — Binance ────────────────────────────────────────────────────────
