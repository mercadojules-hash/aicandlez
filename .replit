modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8084
externalPort = 5173

[[ports]]
localPort = 18150
externalPort = 6800

[[ports]]
localPort = 19240
externalPort = 3002

[[ports]]
localPort = 21259
externalPort = 6000

[[ports]]
localPort = 22060
externalPort = 3001

[[ports]]
localPort = 22061
externalPort = 5000

[[ports]]
localPort = 24210
externalPort = 3000

[userenv]

[userenv.shared]
STRIPE_PRICE_STARTER_MONTHLY = "price_1TcQDxI3nFFqtg3anZqn26u9"
STRIPE_PRICE_PRO_MONTHLY = "price_1TZI2Fi3nFFqtg3aXIMxGhOP"
STRIPE_PRICE_ELITE_MONTHLY = "price_1TcQGWI3nFFqtg3atoJDW2NX"
STRIPE_PRICE_STARTER_LEGACY = "price_1TZPqFIzLCdrkUtzWyDLLMmA"
STRIPE_PRICE_PRO_LEGACY = "price_1TZPqGIzLCdrkUtzMVJLcxb1"
LIVE_EXECUTION_CONCURRENT_CAP = "25"

[userenv.development]
